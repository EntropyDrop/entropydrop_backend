# Copy this file to .env for local development.
# Never commit real credentials, production URLs, or private keys.

# App
ENVIRONMENT=development
STRICT_CONFIG_VALIDATION=false
DATABASE_URL=sqlite:///./ed_dev.db
REDIS_URL=redis://localhost:6379/0
AUTO_CREATE_TABLES=false
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
ADMIN_EMAILS=
# Comma-separated proxy IP/CIDR list allowed to supply X-Forwarded-For/X-Real-IP.
TRUSTED_PROXY_CIDRS=

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_PRIVATE_BUCKET_NAME=
AWS_CDN_DOMAIN=
AWS_DOMAIN_NAME=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_PRO_PLUS_PLAN_ID=
PAYPAL_PRO_MAX_PLAN_ID=
PAYPAL_WEBHOOK_ID=

# Public ledger sync
LEDGER_SYNC_INTERVAL_SECONDS=86400
LEDGER_PAYPAL_LOOKBACK_DAYS=3
LEDGER_AWS_LOOKBACK_DAYS=30

# Model paths
FLUX_MODEL_DIR=
FLUX_LORA_DIR=
ZIMAGE_MODEL_DIR=
